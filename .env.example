# .env.example — TricorderKit v0.7
# Copier vers .env et remplir les valeurs
# IMPORTANT : ne jamais committer .env

# ── Encodage (Windows) ─────────────────────────────────────────────────────
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# ── Claude / Anthropic ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ── Neo4j ─────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-in-prod

# ── Qdrant ────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Temporal ──────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233

# ── Langfuse ──────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_NEXTAUTH_SECRET=change-me-in-prod
LANGFUSE_SALT=change-me-in-prod

# ── Obsidian ──────────────────────────────────────────────────────────────
# Set to your local Obsidian vault path
# Examples:
#   Windows : C:/Users/<your-username>/path/to/your/vault
#   macOS   : /Users/<your-username>/path/to/your/vault
#   Linux   : /home/<your-username>/path/to/your/vault
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
