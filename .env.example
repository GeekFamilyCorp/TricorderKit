# .env.example — TricorderKit v0.7
# Copier vers .env et remplir les valeurs réelles
# IMPORTANT : ne jamais committer .env (déjà dans .gitignore)

# ── Encodage (Windows) ─────────────────────────────────────────────────────
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# ── Claude / Anthropic ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── GitHub ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here

# ── Neo4j ─────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=generate_a_strong_password_here

# ── Qdrant ────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Temporal ──────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233

# ── Langfuse ──────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=http://localhost:3001   # ⚠️ Port 3000 occupé en permanence par Docker Desktop sur Windows
LANGFUSE_NEXTAUTH_SECRET=generate_a_strong_secret_here
LANGFUSE_SALT=generate_a_strong_salt_here

# ── Obsidian ──────────────────────────────────────────────────────────────
# Set to your local Obsidian vault path
# Examples:
#   Windows : C:/Users/<your-username>/path/to/your/vault
#   macOS   : /Users/<your-username>/path/to/your/vault
#   Linux   : /home/<your-username>/path/to/your/vault
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# -- Secrets DB (DEC-040 - rotation A2 2026-06) --------------------------
# Generes localement (ex: 28 caracteres alphanumeriques aleatoires).
# Les composes echouent explicitement si absents (syntaxe ${VAR:?...}).
TEMPORAL_DB_PASSWORD=generate_a_strong_password_here
LANGFUSE_DB_PASSWORD=generate_a_strong_password_here
LANGFUSE_NEXTAUTH_SECRET=generate_a_strong_secret_here
LANGFUSE_SALT=generate_a_strong_salt_here