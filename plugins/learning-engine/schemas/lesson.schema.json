{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tricorderkit://learning-engine/lesson.schema.json",
  "title": "Lesson",
  "description": "Leçon opérationnelle extraite des runs — observation falsifiable + action proposée (Learning Engine §4).",
  "type": "object",
  "required": ["lesson_id", "task_type", "observation", "action", "confidence", "evidence", "status"],
  "additionalProperties": false,
  "properties": {
    "lesson_id": { "type": "string", "pattern": "^[a-z0-9_]+_\\d{3}$" },
    "date": { "type": "string", "format": "date" },
    "task_type": { "type": "string", "minLength": 1 },
    "observation": { "type": "string", "minLength": 10 },
    "action": { "type": "string", "minLength": 5 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "source_runs": { "type": "array", "items": { "type": "string" } },
    "module_impacted": { "type": "string" },
    "skill_impacted": { "type": "string" },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidence_strength": { "type": "number", "minimum": 0, "maximum": 100 },
        "repeatability": { "type": "number", "minimum": 0, "maximum": 100 },
        "regression_risk": { "type": "number", "minimum": 0, "maximum": 100 },
        "complexity_delta": { "type": "number", "minimum": -100, "maximum": 100 }
      }
    },
    "status": { "type": "string", "enum": ["observed", "proposed", "accepted", "rejected", "superseded"] },
    "human_review_required": { "type": "boolean", "default": true }
  }
}
