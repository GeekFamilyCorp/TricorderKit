  "title": "MangaTracker Work Record",
  "type": "object",
  "required": ["category", "action", "source", "confidence_label", "last_checked"],
  "properties": {
    "category": {"type": "string"},
    "action": {"type": "string"},
    "title_jp": {"type": "string"},
