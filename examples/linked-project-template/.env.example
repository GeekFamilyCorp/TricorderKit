# .env.example — Variables d'environnement du projet lié
# Propre au projet lié UNIQUEMENT.
# Les variables TricorderKit (ANTHROPIC_API_KEY, NEO4J_URI, etc.)
# restent dans la racine TricorderKit/.env — ne pas les dupliquer ici.
#
# Copier vers .env et renseigner les valeurs réelles.
# NE PAS versionner .env (ajouter au .gitignore du projet lié).

# ── Identité du projet ────────────────────────────────────────────────────
PROJECT_ID=sample-linked-project
PROJECT_NAME=Sample Linked Project
PROJECT_ENV=development          # development | staging | production

# ── Vault Obsidian ────────────────────────────────────────────────────────
PROJECT_VAULT_PATH=/path/to/private/vault

# ── Base de données locale (si applicable) ────────────────────────────────
PROJECT_DB_URL=sqlite:///data/local.db
# Pour PostgreSQL : postgresql://user:pass@localhost:5432/dbname
# Pour Supabase   : postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── APIs spécifiques au domaine ───────────────────────────────────────────
# Remplacer par les vraies variables de votre domaine.
# Exemples : JIKAN_API_KEY, TMDB_API_KEY, TWITTER_BEARER_TOKEN, etc.
YOUR_DOMAIN_API_KEY=your_domain_api_key_here
YOUR_DOMAIN_API_URL=https://api.your-domain-provider.com/v1

# ── GitHub (repo du projet lié) ───────────────────────────────────────────
# Token GitHub spécifique au projet lié (scope : repo uniquement).
# Différent du token TricorderKit qui a un scope plus large.
PROJECT_GITHUB_TOKEN=your_github_token_here
PROJECT_GITHUB_REPO=your-org/your-repo

# ── Temporal (worker du projet lié) ──────────────────────────────────────
PROJECT_TEMPORAL_TASK_QUEUE=sample-linked-project-tasks

# ── Langfuse (projet séparé optionnel) ────────────────────────────────────
# Laisser vide pour utiliser le projet Langfuse de TricorderKit.
PROJECT_LANGFUSE_PUBLIC_KEY=
PROJECT_LANGFUSE_SECRET_KEY=
