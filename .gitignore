# TricorderKit v0.9 — .gitignore

# Environment
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/

# Cache
.cache/
*.db
*.sqlite
*.sqlite3

# Node
node_modules/
*.js.map
dist/

# Docker
docker/volumes/

# Obsidian
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# OS
.DS_Store
Thumbs.db
*.swp

# Vault — session capsules et données privées
vault/*.json
vault/*.yaml
vault/*.yml

# Reports — générés localement, non versionnés
reports/
vault/reports/

# Audit reports (fichiers générés ponctuellement)
TricorderKit_Audit_*.md

# Logs
*.log
logs/

# IDE
.vscode/settings.json
.idea/

# Configs locales — chemins réels et secrets (non versionnés)
configs/local/linked_projects.yaml
configs/local/settings.yaml
configs/vps/settings.yaml

# Pytest — artefacts locaux
.pytest_tmp/
.pytest_cache/
pytest-cache-files-*/

# Fichiers de sauvegarde
*.bak

# Quarantaine d'audit locale (volumineuse — ne jamais committer)
.quarantine_audit_*/

# --- Ajouts 2026-06-01 (anonymisation / artefacts locaux) ---
# Handoffs de collaboration (operationnel, chemins perso)
a_faire_par_antigravity.md
fait_par_antigravity.md
PROMPT_pour_Antigravity.md
# Donnees de veille locales (linked_project prive)
tools/jp-scraper/
# Scratch diagnostic local
.planning/poc-graphify-index/
# Session capsules (etat operationnel local)
.planning/SESSION_CAPSULE_*.md
# Artefacts d'execution dans les dossiers scripts
plugins/**/scripts/*.txt
plugins/**/scripts/*.out
plugins/**/scripts/*.err
plugins/**/scripts/*_report.json
plugins/**/scripts/*_report.md
plugins/**/scripts/index_state.json
plugins/**/scripts/index_progress.json
plugins/**/scripts/health_heartbeat.log
# Fichiers temp d'anonymisation
_anon.txt
_anon.err

# _sync_antigravity : pont LEGACY DEPRECIE (remplace par canal_agents, bus unifie). Prive en entier.
_sync_antigravity/

# canal_agents : bus multi-agents UNIFIE. Moteur generique PUBLIC (reinstallable) ;
# runtime + contenu PRIVES (supersede DEC-038 : le canal n'est plus 100% prive).
canal_agents/*
!canal_agents/PROTOCOL.md
!canal_agents/scripts
canal_agents/scripts/*
!canal_agents/scripts/sync_bus.py
_userpath_backup_*.txt
_find_bus.txt

# --- Ajouts 2026-06-11 (durcissement frontiere publique) ---
# Backups de rotation (secrets potentiels) : *.bak ne couvre pas les suffixes datés
*.bak-rotation-*
.env.bak*
docker-compose*.bak*
# Scratch diagnostic local à la racine (scripts jetables, agents parallèles)
/_q_*.py
/_run_remote_q.py
/_remote_q.py
/vps_*.py
/_vps_exec.py
/inspect_hk*.py
/dry_hk.py
/repair_run.py
/splice_engine.py
/_patch_*.py
/run*_out.txt
/audit_fiches_raw.csv
/createurs_manquants.csv
