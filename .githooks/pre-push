#!/bin/sh
# Gate anti-fuite avant push (DEC-026) — frontière privé/public.
# Activer une fois : git config core.hooksPath .githooks   (ou: make install-hooks)
#
# Bloque le push si un fichier suivi contient un terme privé (hors whitelist
# .check-anon-ignore) ou un chemin personnel absolu (C:\Users\<nom>, /home/<nom>).

echo "[pre-push] Gate frontiere publique..."

if command -v python >/dev/null 2>&1; then
  PY=python
elif command -v python3 >/dev/null 2>&1; then
  PY=python3
else
  echo "[pre-push] python introuvable — gate non execute, push autorise." >&2
  exit 0
fi

"$PY" scripts/check_public_boundary.py
if [ $? -ne 0 ]; then
  echo ""
  echo "[pre-push] PUSH BLOQUE : fuite detectee dans des fichiers suivis."
  echo "  -> corriger le contenu, OU whitelister un fichier LEGITIME dans .check-anon-ignore."
  echo "  -> les chemins personnels (C:\\Users\\<nom>) ne sont jamais whitelistables."
  exit 1
fi

echo "[pre-push] Gate docs-sync..."
"$PY" scripts/check_docs_sync.py
if [ $? -ne 0 ]; then
  echo ""
  echo "[pre-push] PUSH BLOQUE : vitrine desynchronisee (README/STATUS vs structure/version/tests)."
  echo "  -> corriger README.md / STATUS.md (ou CHANGELOG), puis relancer."
  exit 1
fi

echo "[pre-push] Gate gitleaks (secrets)..."
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git -c .gitleaks.toml --redact --no-banner
  if [ $? -ne 0 ]; then
    echo ""
    echo "[pre-push] PUSH BLOQUE : gitleaks a detecte un secret potentiel dans l'historique."
    echo "  -> retirer le secret (git filter-repo), rotater la valeur exposee, puis relancer."
    echo "  -> faux positif LEGITIME : l'allowlister dans .gitleaks.toml."
    exit 1
  fi
else
  echo "[pre-push] AVERTISSEMENT : gitleaks introuvable — scan secrets NON execute." >&2
  echo "  -> installer gitleaks (winget install Gitleaks.Gitleaks) ; la CI reste le filet serveur." >&2
fi

echo "[pre-push] OK — aucune fuite, vitrine synchronisee, aucun secret."
exit 0
